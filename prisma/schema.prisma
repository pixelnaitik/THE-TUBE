generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  image         String?
  videos        Video[]
  comments      Comment[]
  likes         Like[]
  history       WatchHistory[]
  notifications Notification[]
  subscribers   Subscription[] @relation("SubscribedTo")
  subscribedTo  Subscription[] @relation("Subscriber")
  playlists     Playlist[]
  watchLater    WatchLater[]
  createdAt     DateTime       @default(now())
}

model Video {
  id          String          @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  hlsUrl      String?
  status      String          @default("PROCESSING")
  duration    Int?
  views       Int             @default(0)
  tags        String?         // Comma-separated tags
  authorId    String
  author      User            @relation(fields: [authorId], references: [id])
  comments    Comment[]
  likes       Like[]
  history     WatchHistory[]
  playlists   PlaylistVideo[]
  watchLater  WatchLater[]
  createdAt   DateTime        @default(now())

  @@index([authorId])
  @@index([status, createdAt])
}

model Comment {
  id        String    @id @default(cuid())
  text      String
  videoId   String
  video     Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime  @default(now())

  @@index([videoId])
  @@index([userId])
  @@index([parentId])
}

model Like {
  id      String @id @default(cuid())
  type    String
  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  @@unique([videoId, userId])
  @@index([userId])
}

model Subscription {
  id           String   @id @default(cuid())
  subscriberId String
  subscriber   User     @relation("Subscriber", fields: [subscriberId], references: [id])
  channelId    String
  channel      User     @relation("SubscribedTo", fields: [channelId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([subscriberId, channelId])
  @@index([channelId])
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  watchedAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // NEW_VIDEO, NEW_SUBSCRIBER, NEW_COMMENT
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Playlist {
  id        String          @id @default(cuid())
  name      String
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  videos    PlaylistVideo[]
  createdAt DateTime        @default(now())

  @@index([userId])
}

model PlaylistVideo {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  order      Int
  addedAt    DateTime @default(now())

  @@unique([playlistId, videoId])
  @@index([videoId])
}

model WatchLater {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
}
